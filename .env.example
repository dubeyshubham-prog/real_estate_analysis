# Application
APP_NAME=PropLens
APP_TAGLINE=Real Estate Intelligence, Clearly.
APP_ENV=development
DEBUG=false
HOST=127.0.0.1
PORT=8000
MAX_UPLOAD_SIZE_MB=10
RUNTIME_DIR=./data
ENABLE_VISION=true
USE_OLLAMA_ROUTER=false
DATABASE_URL=sqlite:///./data/proplens.db
RAG_COLLECTION_NAME=real_estate_knowledge
RAG_RESULT_LIMIT=3
WEB_SEARCH_URL=https://html.duckduckgo.com/html/
WEB_SEARCH_FALLBACK_URL=https://www.bing.com/news/search
WEB_SEARCH_TIMEOUT_SECONDS=10

# Logging
LOG_LEVEL=INFO

